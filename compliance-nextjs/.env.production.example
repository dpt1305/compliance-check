# ─────────────────────────────────────────────────────────────────────────────
# EC2 PRODUCTION — copy this file to .env.production on the server and fill in values
# For local development use .env.local.example instead
# ─────────────────────────────────────────────────────────────────────────────

# ── App URL ───────────────────────────────────────────────────────────────────
# Set to your domain (with https once SSL is configured)
STORAGE_IMAGE_BASE_URL=https://your-domain.com/api/images/

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=my-compliance-images
AWS_S3_PREFIX=images

# TTL: submissions in MongoDB and images in S3 are auto-deleted after this many days.
# Also controls the S3 bucket lifecycle rule applied at startup (requires s3:PutLifecycleConfiguration).
SUBMISSION_TTL_DAYS=90

# EC2 PRODUCTION: DO NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here.
# The EC2 IAM Instance Role (ComplianceEC2Role) provides credentials automatically
# via the AWS instance metadata service. Hardcoding keys is a security risk.
#
# AWS_ACCESS_KEY_ID=      <-- intentionally omitted
# AWS_SECRET_ACCESS_KEY=  <-- intentionally omitted

# ── File Storage (absolute paths inside the app directory on EC2) ─────────────
# IMPORTANT: Use absolute paths so data survives git pull + npm run build redeploys.
SQLITE_DB_PATH=/home/ubuntu/compliance-check/compliance-nextjs/data/compliance.db

# MongoDB — set MONGODB_URI to switch from SQLite to MongoDB (recommended for production)
# When set, the app auto-migrates data from SQLite on first startup.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/compliance
# MONGODB_DB_NAME=compliance

STORAGE_IMAGE_PATH=/home/ubuntu/compliance-app/compliance-nextjs/data/images
STORAGE_JSON_PATH=/home/ubuntu/compliance-app/compliance-nextjs/data/submissions.json
STORAGE_JSON_ADMIN_PATH=/home/ubuntu/compliance-app/compliance-nextjs/data/admins.json
EXCEL_UPDATE_PATH=/home/ubuntu/compliance-app/compliance-nextjs/data/tracking.xlsx

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_HOURS=1

# ── AI Providers ──────────────────────────────────────────────────────────────
AI_GEMINI_ENABLED=true
AI_GEMINI_ORDER=0
GEMINI_API_KEY=
AI_GEMINI_ENDPOINT=https://aiportalapi.stu-platform.live/jpe
AI_GEMINI_MODEL=Gemini-3.1-Flash-Lite

AI_CHATGPT_ENABLED=true
AI_CHATGPT_ORDER=1
CHATGPT_API_KEY=
AI_CHATGPT_ENDPOINT=https://aiportalapi.stu-platform.live/use
CHATGPT_MODEL=GPT-5-mini

AI_NVIDIA_ENABLED=false
AI_NVIDIA_ORDER=2
NVIDIA_API_KEY=
AI_NVIDIA_ENDPOINT=
AI_NVIDIA_MODEL=

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFICATION_MODE=teams
TEAMS_WEBHOOK_URL=
DEADLINE_DATE=
REMINDER_DAYS_BEFORE=7
NOTIFICATION_MESSAGE=Please submit your compliance documents before the deadline.

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=20

# ── Attendance API ────────────────────────────────────────────────────────────
# Shared secret for the external attendance system calling POST /api/attendance.
# REQUIRED in production — generate with: openssl rand -hex 32
# The external server must send this as: x-api-key: <value>  (or Bearer token)
ATTENDANCE_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ENABLE_DYNAMIC_FORM
ENABLE_DYNAMIC_FORM=true