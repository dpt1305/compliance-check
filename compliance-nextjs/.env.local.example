# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — copy this file to .env.local and fill in your values
# For EC2 production use .env.production.example instead
# ─────────────────────────────────────────────────────────────────────────────

# ── App URL ───────────────────────────────────────────────────────────────────
STORAGE_IMAGE_BASE_URL=http://localhost:3000/api/images/

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Set AWS_S3_BUCKET to store images in S3.
# Leave it blank to fall back to local ./data/images/ folder instead.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=images

# LOCAL DEV: explicit IAM user credentials are required (no EC2 instance role here)
# Create an IAM user in AWS Console with ComplianceS3Policy attached, then paste keys below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── File Storage (local filesystem — always used for JSON + Excel) ────────────
# SQLITE_DB_PATH: set an absolute path in production so DB survives redeploys
# SQLITE_DB_PATH=/absolute/path/to/compliance.db
STORAGE_IMAGE_PATH=./data/images
STORAGE_JSON_PATH=./data/submissions.json
STORAGE_JSON_ADMIN_PATH=./data/admins.json
EXCEL_UPDATE_PATH=./data/tracking.xlsx

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme-replace-in-production-must-be-256-bits-long!!
JWT_EXPIRY_HOURS=1

# ── AI Providers ──────────────────────────────────────────────────────────────
AI_GEMINI_ENABLED=true
AI_GEMINI_ORDER=0
GEMINI_API_KEY=
AI_GEMINI_ENDPOINT=https://aiportalapi.stu-platform.live/jpe
AI_GEMINI_MODEL=Gemini-3.1-Flash-Lite

AI_CHATGPT_ENABLED=true
AI_CHATGPT_ORDER=1
CHATGPT_API_KEY=
AI_CHATGPT_ENDPOINT=https://aiportalapi.stu-platform.live/use
CHATGPT_MODEL=GPT-5-mini

AI_NVIDIA_ENABLED=false
AI_NVIDIA_ORDER=2
NVIDIA_API_KEY=
AI_NVIDIA_ENDPOINT=
AI_NVIDIA_MODEL=

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFICATION_MODE=teams
TEAMS_WEBHOOK_URL=
DEADLINE_DATE=
REMINDER_DAYS_BEFORE=7
NOTIFICATION_MESSAGE=Please submit your compliance documents before the deadline.

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=20

# ── Attendance API ────────────────────────────────────────────────────────────
# Shared secret for the external attendance system calling POST /api/attendance.
# Leave blank to disable auth (development only — never leave blank in production).
ATTENDANCE_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
